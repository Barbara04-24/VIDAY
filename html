<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TikTok Aesthetic</title>

  <!-- Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:'Poppins',sans-serif;
    }

    body{
      overflow:hidden;
      background:#000;
    }

    /* VIDEO */
    video{
      position:fixed;
      top:0;
      left:0;
      width:100%;
      height:100%;
      object-fit:cover;
      z-index:-3;
      filter:brightness(0.6);
    }

    /* OVERLAY GRADIENT */
    .overlay{
      position:fixed;
      width:100%;
      height:100%;
      background:linear-gradient(
        to top,
        rgba(0,0,0,0.8),
        rgba(0,0,0,0.1)
      );
      z-index:-2;
    }

    /* EFFECT */
    .glow{
      position:absolute;
      width:300px;
      height:300px;
      border-radius:50%;
      background:#ff0050;
      filter:blur(150px);
      opacity:0.5;
      top:20%;
      left:10%;
      animation:move 8s infinite alternate;
    }

    .glow2{
      position:absolute;
      width:300px;
      height:300px;
      border-radius:50%;
      background:#00f2ea;
      filter:blur(150px);
      opacity:0.5;
      bottom:10%;
      right:10%;
      animation:move2 8s infinite alternate;
    }

    @keyframes move{
      from{
        transform:translate(0,0);
      }
      to{
        transform:translate(100px,50px);
      }
    }

    @keyframes move2{
      from{
        transform:translate(0,0);
      }
      to{
        transform:translate(-100px,-50px);
      }
    }

    /* CONTENT */
    .content{
      width:100%;
      height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      flex-direction:column;
      color:white;
      text-align:center;
      padding:20px;
    }

    .content h1{
      font-size:60px;
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:5px;
      animation:flicker 2s infinite alternate;
    }

    .content p{
      margin-top:15px;
      font-size:18px;
      opacity:0.9;
    }

    .btn{
      margin-top:30px;
      padding:14px 40px;
      border:none;
      border-radius:50px;
      background:linear-gradient(45deg,#ff0050,#00f2ea);
      color:white;
      font-size:16px;
      font-weight:bold;
      cursor:pointer;
      transition:0.3s;
      box-shadow:0 0 20px rgba(255,0,80,0.6);
    }

    .btn:hover{
      transform:scale(1.08);
      box-shadow:0 0 30px rgba(0,242,234,0.8);
    }

    @keyframes flicker{
      from{
        text-shadow:
        0 0 10px #fff,
        0 0 20px #ff0050,
        0 0 40px #00f2ea;
      }
      to{
        text-shadow:
        0 0 20px #fff,
        0 0 40px #ff0050,
        0 0 80px #00f2ea;
      }
    }

    /* MUSIC INFO */
    .music{
      position:absolute;
      bottom:30px;
      left:20px;
      color:white;
      font-size:14px;
      opacity:0.8;
      animation:slide 3s infinite alternate;
    }

    @keyframes slide{
      from{
        transform:translateX(0);
      }
      to{
        transform:translateX(10px);
      }
    }

  </style>
</head>
<body>

  <!-- VIDEO -->
  <video autoplay muted loop>
    <source src="tiktok.mp4" type="video/mp4">
  </video>

  <!-- EFFECT -->
  <div class="overlay"></div>
  <div class="glow"></div>
  <div class="glow2"></div>

  <!-- CONTENT -->
  <div class="content">
    <h1>TIKTOK VIBES</h1>
    <p>night drive • lonely • aesthetic ✨</p>
    <button class="btn">PLAY NOW</button>
  </div>

  <!-- MUSIC -->
  <div class="music">
    🎵 DJ Slow Remix - Aesthetic Sound
  </div>

</body>
</html>